pipeline {
    agent any

    stages {

        stage('Build Docker Image') {
            steps {
                sh 'sudo docker build -t flaskmongo:v1 .'
            }
        }

        stage('Deploy Container') {
            steps {
                sh 'sudo docker rm -f flaskapp || true'
                sh 'sudo docker run -d --name flaskapp --network devops-network -p 5000:5000 flaskmongo:v1'
            }
        }
    }
}
